<article>
  <div class="row">
    <div class="col-md-4 mb-4">
      {{#if disease.thumbnail}}
        <img src="{{disease.thumbnail}}" class="img-fluid rounded mb-3" alt="{{disease.name}}">
      {{else}}
        <div class="bg-light p-5 text-center text-muted rounded">
          Imagen no disponible
        </div>
      {{/if}}
      
      <div class="card mb-3">
        <div class="card-header bg-primary text-white">
          <h2 class="h5 mb-0">Detalles de la Enfermedad</h2>
        </div>
        <ul class="list-group list-group-flush">
          {{#if disease.designer}}
            <li class="list-group-item">
              <strong>Diseñador:</strong> {{disease.designer}}
            </li>
          {{/if}}
          {{#if disease.year}}
            <li class="list-group-item">
              <strong>Año:</strong> {{disease.year}}
            </li>
          {{/if}}
          {{#if disease.minPlayers}}
            <li class="list-group-item">
              <strong>Pacientes / población:</strong> {{disease.minPlayers}} 
              {{#if disease.maxPlayers}}- {{disease.maxPlayers}}{{/if}}
            </li>
          {{/if}}
          {{#if disease.playingTime}}
            <li class="list-group-item">
              <strong>Curso clínico o duración:</strong> {{disease.playingTime}} minutos
            </li>
          {{/if}}
          {{#if disease.genre}}
            <li class="list-group-item">
              <strong>Género:</strong> {{disease.genre}}
            </li>
          {{/if}}
          {{#if disease.mechanic}}
            <li class="list-group-item">
              <strong>Mecánica:</strong> {{disease.mechanic}}
            </li>
          {{/if}}
          {{#if disease.publisher}}
            <li class="list-group-item">
              <strong>Editorial:</strong> {{disease.publisher}}
            </li>
          {{/if}}
        </ul>
      </div>
    </div>
    
    <div class="col-md-8">
      <h1 class="mb-3">{{disease.name}}</h1>
      
      <div class="mb-4">
        <h2 class="h4">Descripción</h2>
        <p>{{disease.abstract}}</p>
      </div>
      
      <div class="d-flex justify-content-between">
        <a href="/search?q={{encodeURIComponent (split disease.name ' '.[0])}}" class="btn btn-outline-secondary">
          Volver a resultados
        </a>
        <a href="{{disease.uri}}" class="btn btn-outline-primary" target="_blank" rel="noopener">
          Ver en DBpedia
        </a>
      </div>
    </div>
  </div>
</article>