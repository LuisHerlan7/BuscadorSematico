<article class="beca-detail-page">
  <div class="beca-detail-container">

    <!-- Columna izquierda: imagen + datos clave -->
    <aside class="beca-sidebar">
      {{#if disease.thumbnail}}
        <div class="beca-thumbnail-wrapper">
          <img src="{{disease.thumbnail}}" class="beca-thumbnail" alt="{{disease.name}}" loading="lazy">
        </div>
      {{else}}
        <div class="beca-thumbnail-placeholder">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" fill="none">
            <circle cx="32" cy="32" r="32" fill="#312e81" opacity="0.15"/>
            <path d="M32 14 L54 26 L54 38 C54 50 43 58 32 62 C21 58 10 50 10 38 L10 26 Z"
                  fill="#4f46e5" opacity="0.25"/>
            <path d="M22 32 L30 40 L42 26" stroke="#6366f1" stroke-width="3"
                  stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>Beca Universitaria</span>
        </div>
      {{/if}}

      <div class="beca-info-card">
        <h2 class="beca-info-title">Información General</h2>
        <ul class="beca-info-list">

          {{#if disease.source}}
          <li class="beca-info-item">
            <span class="beca-info-icon">🌐</span>
            <div>
              <span class="beca-info-label">Fuente</span>
              <span class="beca-info-value source-badge {{disease.source}}">
                {{#if (eq disease.source 'dbpedia')}}DBpedia{{else}}Local{{/if}}
              </span>
            </div>
          </li>
          {{/if}}

          {{#if disease.amount}}
          <li class="beca-info-item">
            <span class="beca-info-icon">💰</span>
            <div>
              <span class="beca-info-label">Monto Cubierto</span>
              <span class="beca-info-value">{{disease.amount}}</span>
            </div>
          </li>
          {{/if}}

          {{#if disease.deadline}}
          <li class="beca-info-item">
            <span class="beca-info-icon">📅</span>
            <div>
              <span class="beca-info-label">Fecha Límite</span>
              <span class="beca-info-value">{{disease.deadline}}</span>
            </div>
          </li>
          {{/if}}

        </ul>
      </div>
    </aside>

    <!-- Columna derecha: nombre, descripción, acciones -->
    <main class="beca-main">
      <header class="beca-header">
        <div class="beca-badge">Beca Universitaria</div>
        <h1 class="beca-name">{{disease.name}}</h1>
      </header>

      <section class="beca-description">
        <h2 class="section-heading">Descripción</h2>
        {{#if disease.abstract}}
          <p>{{disease.abstract}}</p>
        {{else}}
          <p class="no-desc">No hay descripción disponible para esta beca.</p>
        {{/if}}
      </section>

      <div class="beca-actions">
        <a href="/search?q={{disease.name}}" class="btn-back">
          ← Volver a resultados
        </a>
        {{#if disease.uri}}
          <a href="{{disease.uri}}" class="btn-dbpedia" target="_blank" rel="noopener noreferrer">
            Ver en DBpedia ↗
          </a>
        {{/if}}
      </div>
    </main>
  </div>
</article>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');

  :root {
    --primary:   #4f46e5;
    --primary-light: #818cf8;
    --dark:      #1e1b4b;
    --card-bg:   #ffffff;
    --bg:        #f5f3ff;
    --border:    #e0e7ff;
    --text:      #1f2937;
    --muted:     #6b7280;
    --radius:    16px;
    --shadow:    0 8px 32px rgba(79,70,229,0.10);
  }

  .beca-detail-page {
    font-family: 'Inter', sans-serif;
    background: var(--bg);
    min-height: 100vh;
    padding: 2rem 1rem;
  }

  .beca-detail-container {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 2rem;
    align-items: start;
  }

  /* ── Sidebar ── */
  .beca-sidebar { display: flex; flex-direction: column; gap: 1.5rem; }

  .beca-thumbnail-wrapper {
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow);
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }
  .beca-thumbnail { width: 100%; max-height: 220px; object-fit: contain; }

  .beca-thumbnail-placeholder {
    background: linear-gradient(135deg, #ede9fe 0%, #c7d2fe 100%);
    border-radius: var(--radius);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 3rem 1.5rem;
    gap: 0.75rem;
    color: var(--primary);
    font-weight: 600;
    font-size: 0.9rem;
  }
  .beca-thumbnail-placeholder svg { width: 64px; height: 64px; }

  .beca-info-card {
    background: var(--card-bg);
    border-radius: var(--radius);
    padding: 1.5rem;
    box-shadow: var(--shadow);
    border: 1px solid var(--border);
  }
  .beca-info-title {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: var(--muted);
    margin: 0 0 1rem;
  }
  .beca-info-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: .85rem; }
  .beca-info-item {
    display: flex;
    align-items: flex-start;
    gap: .75rem;
  }
  .beca-info-icon { font-size: 1.25rem; flex-shrink: 0; margin-top: 2px; }
  .beca-info-label { display: block; font-size: .7rem; color: var(--muted); text-transform: uppercase; letter-spacing: .06em; }
  .beca-info-value { display: block; font-size: .9rem; font-weight: 600; color: var(--text); margin-top: 2px; }

  .source-badge {
    display: inline-block;
    padding: 2px 10px;
    border-radius: 99px;
    font-size: .75rem !important;
    font-weight: 600 !important;
  }
  .source-badge.dbpedia { background: #dbeafe; color: #1d4ed8; }
  .source-badge.local   { background: #d1fae5; color: #065f46; }

  /* ── Main ── */
  .beca-main {
    background: var(--card-bg);
    border-radius: var(--radius);
    padding: 2.5rem;
    box-shadow: var(--shadow);
    border: 1px solid var(--border);
  }

  .beca-header { margin-bottom: 1.5rem; }
  .beca-badge {
    display: inline-block;
    background: linear-gradient(90deg, #4f46e5, #818cf8);
    color: #fff;
    font-size: .7rem;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    padding: 4px 14px;
    border-radius: 99px;
    margin-bottom: .75rem;
  }
  .beca-name {
    font-size: 2rem;
    font-weight: 800;
    color: var(--dark);
    line-height: 1.25;
    margin: 0;
  }

  .section-heading {
    font-size: 1rem;
    font-weight: 700;
    color: var(--primary);
    margin: 0 0 .75rem;
    border-bottom: 2px solid var(--border);
    padding-bottom: .5rem;
  }

  .beca-description p {
    color: var(--text);
    line-height: 1.75;
    font-size: .95rem;
    margin: 0;
  }
  .no-desc { color: var(--muted) !important; font-style: italic; }

  .beca-actions {
    margin-top: 2rem;
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .btn-back, .btn-dbpedia {
    display: inline-flex;
    align-items: center;
    padding: .6rem 1.4rem;
    border-radius: 10px;
    font-size: .875rem;
    font-weight: 600;
    text-decoration: none;
    transition: all .2s ease;
  }
  .btn-back {
    background: var(--bg);
    color: var(--primary);
    border: 2px solid var(--border);
  }
  .btn-back:hover { background: #ede9fe; border-color: var(--primary-light); }

  .btn-dbpedia {
    background: linear-gradient(135deg, #4f46e5, #818cf8);
    color: #fff;
    border: 2px solid transparent;
    box-shadow: 0 4px 15px rgba(79,70,229,.35);
  }
  .btn-dbpedia:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(79,70,229,.45); }

  @media (max-width: 768px) {
    .beca-detail-container { grid-template-columns: 1fr; }
    .beca-name { font-size: 1.5rem; }
    .beca-main { padding: 1.5rem; }
  }
</style>