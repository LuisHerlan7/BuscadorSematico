<h1 class="results-title">
  {{#if (eq lang 'es')}}Resultados para "{{query}}"{{/if}}
  {{#if (eq lang 'en')}}Results for "{{query}}"{{/if}}
  {{#if (eq lang 'pt')}}Resultados para "{{query}}"{{/if}}
  {{#if (eq lang 'de')}}Ergebnisse für "{{query}}"{{/if}}
  {{#if (eq lang 'fr')}}Résultats pour "{{query}}"{{/if}}
</h1>

{{#if isEmpty}}
  <div class="no-results">
    {{#if (eq lang 'es')}}No se encontraron becas que coincidan con tu búsqueda.{{/if}}
    {{#if (eq lang 'en')}}No scholarships found matching your search.{{/if}}
    {{#if (eq lang 'pt')}}Nenhuma bolsa encontrada correspondente à sua pesquisa.{{/if}}
    {{#if (eq lang 'de')}}Keine Stipendien gefunden, die Ihrer Suche entsprechen.{{/if}}
    {{#if (eq lang 'fr')}}Aucune bourse trouvée correspondant à votre recherche.{{/if}}
  </div>
{{else}}
  <div class="diseases-grid">
    {{#each diseases}}
      <div class="disease-card">
        <!-- Encabezado con el nombre de la beca -->
        <div class="disease-header">
          <h2 class="disease-title">{{label}}</h2>
          {{#if name}}
            <div class="disease-subtitle">{{name}}</div>
          {{/if}}
        </div>

        <!-- Imagen (si existe) -->
        {{#if thumbnail}}
          <div class="disease-image-container">
            <img src="{{thumbnail}}" class="disease-image" alt="{{label}}" loading="lazy">
          </div>
        {{/if}}

        <!-- Cuerpo con descripción -->
        <div class="disease-body">
          {{#if genre}}
            <div class="disease-tag genre-tag">
              <svg xmlns="http://www.w3.org/2000/svg" class="tag-icon" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M17.707 9.293a1 1 0 010 1.414l-7 7a1 1 0 01-1.414 0l-7-7A.997.997 0 012 10V5a3 3 0 013-3h5c.256 0 .512.098.707.293l7 7zM5 6a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
              </svg>
              <span>{{genre}}</span>
            </div>
          {{/if}}
          
          <p class="disease-abstract">{{#if description}}{{truncate description 800}}{{else}}{{truncate abstract 800}}{{/if}}</p>
          
          <!-- Detalles adicionales -->
          <div class="disease-details">
            {{#if amount}}
              <div class="detail-item">
                <svg xmlns="http://www.w3.org/2000/svg" class="detail-icon" viewBox="0 0 20 20" fill="currentColor"><path d="M10 2a6 6 0 100 12 6 6 0 000-12zM8 9h4v1H8V9z"/></svg>
                <div class="detail-text">
                  <span class="detail-label">{{#if (eq ../lang 'es')}}Monto{{else}}Amount{{/if}}</span>
                  <span class="detail-value">{{amount}}</span>
                </div>
              </div>
            {{/if}}

            {{#if deadline}}
              <div class="detail-item">
                <svg xmlns="http://www.w3.org/2000/svg" class="detail-icon" viewBox="0 0 20 20" fill="currentColor"><path d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v8a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H8V3a1 1 0 00-1-1z"/></svg>
                <div class="detail-text">
                  <span class="detail-label">{{#if (eq ../lang 'es')}}Fecha límite{{else}}Deadline{{/if}}</span>
                  <span class="detail-value">{{deadline}}</span>
                </div>
              </div>
            {{/if}}

            {{#if source}}
              <div class="detail-item">
                <svg xmlns="http://www.w3.org/2000/svg" class="detail-icon" viewBox="0 0 20 20" fill="currentColor"><path d="M12.293 2.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414l8-8z"/></svg>
                <div class="detail-text">
                  <span class="detail-label">{{#if (eq ../lang 'es')}}Fuente{{else}}Source{{/if}}</span>
                  <span class="detail-value">{{source}}</span>
                </div>
              </div>
            {{/if}}
          </div>
        </div>

        <!-- Enlace a la página del enfermedad -->
        <div class="disease-footer">
          <h3 class="references-title">
            {{#if (eq ../lang 'es')}}Enlaces{{/if}}
            {{#if (eq ../lang 'en')}}Links{{/if}}
            {{#if (eq ../lang 'pt')}}Links{{/if}}
            {{#if (eq ../lang 'de')}}Links{{/if}}
            {{#if (eq ../lang 'fr')}}Links{{/if}}
          </h3>
          <div class="disease-links">
            {{#if uri}}
              <a href="{{uri}}" class="disease-link" target="_blank" rel="noopener noreferrer">
                <svg xmlns="http://www.w3.org/2000/svg" class="link-icon" viewBox="0 0 20 20" fill="currentColor"><path d="M12.293 2.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414l8-8z"/></svg>
                <span>{{#if (eq ../lang 'es')}}Ver en fuente{{else}}View source{{/if}}</span>
              </a>
            {{/if}}
            {{#if dbpediaPage}}
              <a href="{{dbpediaPage}}" class="disease-link" target="_blank" rel="noopener noreferrer">
                <svg xmlns="http://www.w3.org/2000/svg" class="link-icon" viewBox="0 0 20 20" fill="currentColor"><path d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1z"/></svg>
                <span>DBpedia</span>
              </a>
            {{/if}}

            <!-- Acciones rápidas: Guardar en localStorage -->
            <button class="disease-link save-btn" data-uri="{{uri}}" data-label="{{label}}">{{#if (eq ../lang 'es')}}Guardar{{else}}Save{{/if}}</button>
          </div>
        </div>
      </div>
    {{/each}}
  </div>
{{/if}}

<style>
  :root {
    --primary-color: #4f46e5;
    --secondary-color: #6366f1;
    --text-color: #1f2937;
    --light-text: #6b7280;
    --bg-color: #f9fafb;
    --card-bg: #ffffff;
    --border-color: #e5e7eb;
    --shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    --radius: 12px;
    --transition: all 0.3s ease;
  }

  .results-title {
    font-size: 2rem;
    font-weight: 700;
    color: var(--text-color);
    margin-bottom: 2rem;
    text-align: center;
  }

  .no-results {
    text-align: center;
    padding: 2rem;
    background-color: var(--card-bg);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    color: var(--light-text);
    max-width: 600px;
    margin: 0 auto;
  }

  .diseases-grid {
    gap: 2rem;
    padding: 1rem 0;
  }

  .disease-card {
    background-color: var(--card-bg);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow);
    transition: var(--transition);
    display: flex;
    flex-direction: column;
  }

  .disease-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
  }

  .disease-header {
    padding: 1.5rem 1.5rem 0;
  }

  .disease-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text-color);
    margin: 0;
  }

  .disease-image-container {
    width: 100%;
    overflow: hidden;
    margin: 1rem 0;
  }

  .disease-image {
    object-fit: cover;
    transition: var(--transition);
    display: flex;
margin: 0 auto;
  }

  .disease-card:hover .disease-image {
    transform: scale(1.05);
  }

  .disease-body {
    padding: 0 1.5rem;
    flex-grow: 1;
  }

  .disease-tag {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 500;
    margin-bottom: 1rem;
    background-color: #e0e7ff;
    color: var(--primary-color);
  }

  .tag-icon {
    width: 0.75rem;
    height: 0.75rem;
    margin-right: 0.25rem;
  }

  .disease-abstract {
    color: var(--light-text);
    font-size: 0.875rem;
    line-height: 1.5;
    margin-bottom: 1.5rem;
  }

  .disease-details {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .detail-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .detail-icon {
    width: 1rem;
    height: 1rem;
    color: var(--light-text);
    flex-shrink: 0;
  }

  .detail-text {
    display: flex;
    flex-direction: column;
  }

  .detail-label {
    font-size: 0.75rem;
    color: var(--light-text);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .detail-value {
    font-size: 0.875rem;
    color: var(--text-color);
    font-weight: 500;
  }

  .disease-footer {
    padding: 1rem 1.5rem;
    background-color: #f8f9fa;
    border-top: 1px solid var(--border-color);
  }

  .references-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--light-text);
    margin-bottom: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .disease-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .disease-link {
    display: inline-flex;
    align-items: center;
    padding: 0.375rem 0.75rem;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--primary-color);
    background-color: #e0e7ff;
    text-decoration: none;
    transition: var(--transition);
  }

  .disease-link:hover {
    background-color: #c7d2fe;
    color: #4338ca;
  }

  .link-icon {
    width: 0.75rem;
    height: 0.75rem;
    margin-right: 0.375rem;
  }

  @media (max-width: 768px) {
    .diseases-grid {
      grid-template-columns: 1fr;
    }
    
    .results-title {
      font-size: 1.5rem;
    }
  }
</style>

<script>
  (function(){
    function getFavs(){
      try{ return JSON.parse(localStorage.getItem('favs')||'[]'); }catch(e){return []}
    }
    function saveFav(item){
      const favs = getFavs();
      if(!favs.find(f=>f.uri===item.uri)){
        favs.push(item);
        localStorage.setItem('favs', JSON.stringify(favs));
        return true;
      }
      return false;
    }

    document.querySelectorAll('.save-btn').forEach(btn=>{
      btn.addEventListener('click', ()=>{
        const uri = btn.getAttribute('data-uri');
        const label = btn.getAttribute('data-label');
        if(!uri) return alert('URI no disponible');
        const ok = saveFav({ uri, label });
        if(ok) {
          btn.textContent = 'Guardado';
          btn.disabled = true;
        } else {
          btn.textContent = 'Ya guardado';
        }
      });
    });
  })();
</script>