#################################################################
# Esquema minimo usado por las consultas locales
#################################################################

becas:Beca rdfs:label "Beca"@es .

becas:BecaCompleta rdfs:subClassOf becas:Beca ;
  rdfs:label "Beca Completa"@es .

becas:BecaParcial rdfs:subClassOf becas:Beca ;
  rdfs:label "Beca Parcial"@es .

becas:BecaDeExcelencia rdfs:subClassOf becas:Beca ;
  rdfs:label "Beca de Excelencia"@es .

becas:BecaSocioeconomica rdfs:subClassOf becas:BecaSocioeconómica .

becas:BecaSocioeconómica rdfs:subClassOf becas:Beca ;
  rdfs:label "Beca Socioeconómica"@es .

becas:BecaDeMovilidad rdfs:subClassOf becas:Beca ;
  rdfs:label "Beca de Movilidad"@es .

becas:BecaDeIntercambio rdfs:subClassOf becas:BecaDeMovilidad ;
  rdfs:label "Beca de Intercambio"@es .

becas:BecaDeInvestigacion rdfs:subClassOf becas:Beca ;
  rdfs:label "Beca de Investigacion"@es .

becas:BecaDePostdoctorado rdfs:subClassOf becas:BecaDeInvestigacion ;
  rdfs:label "Beca de Postdoctorado"@es .

