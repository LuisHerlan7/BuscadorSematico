    <!-- INSTANCIAS DE: País
    <owl:NamedIndividual rdf:about="#Bolivia">
        <rdf:type rdf:resource="#País"/>
        <nombreInstitucion>Bolivia</nombreInstitucion>
    </owl:NamedIndividual>
    -->

    <!-- INSTANCIAS DE: Convocatoria
    <owl:NamedIndividual rdf:about="#NombreDeTuConvocatoria">
        <rdf:type rdf:resource="#ConvocatoriaNacional"/>
        <fechaInicio rdf:datatype="&xsd;date">2025-03-01</fechaInicio>
        <fechaLímitePostulación rdf:datatype="&xsd;date">2025-05-31</fechaLímitePostulación>
        <fechaDeResultados rdf:datatype="&xsd;date">2025-07-01</fechaDeResultados>
        <tieneProcesoDeSelección rdf:resource="#NombreDeTuProceso"/>
    </owl:NamedIndividual>
    -->

    <!-- INSTANCIAS DE: Postulante / Beneficiario
    <owl:NamedIndividual rdf:about="#NombreDelEstudiante">
        <rdf:type rdf:resource="#Beneficiario"/>
        <nombreCompleto>Nombre Apellido</nombreCompleto>
        <correoElectrónico>correo@ejemplo.com</correoElectrónico>
        <esBeneficiarioDe rdf:resource="#NombreDeTuBeca"/>
    </owl:NamedIndividual>
    -->

    <!-- INSTANCIAS DE: Requisito
    <owl:NamedIndividual rdf:about="#RequisitoPromedio">
        <rdf:type rdf:resource="#RequisitoAcadémico"/>
        <promedioMínimo rdf:datatype="&xsd;decimal">7.0</promedioMínimo>
    </owl:NamedIndividual>
    -->

    <!-- INSTANCIAS DE: Organismo / Patrocinador
    <owl:NamedIndividual rdf:about="#NombreDelOrganismo">
        <rdf:type rdf:resource="#OrganismoGubernamental"/>
