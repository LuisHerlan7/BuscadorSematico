        <descripción>Descripción breve</descripción>
        <duración rdf:datatype="&xsd;integer">24</duración>
        <esRenovable rdf:datatype="&xsd;boolean">true</esRenovable>
        <perteneceANivel rdf:resource="#Maestría"/>
        <perteneceAÁrea rdf:resource="#Tecnología"/>
        <esOfrecidaPor rdf:resource="#NombreDeTuInstitucion"/>
    </owl:NamedIndividual>
    -->

    <!-- INSTANCIAS DE: Universidad / Institución
    <owl:NamedIndividual rdf:about="#NombreDeTuInstitucion">
        <rdf:type rdf:resource="#Universidad"/>
        <nombreInstitucion>Nombre oficial</nombreInstitucion>
        <seDesarrollaEn rdf:resource="#Bolivia"/>
    </owl:NamedIndividual>
